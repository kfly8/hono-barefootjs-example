{
  "name": "hono-barefootjs-example",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n build,server -c blue,green \"bf build --watch\" \"bunx wrangler dev --live-reload\"",
    "build": "bf build",
    "deploy": "bf build && bunx wrangler deploy",
    "watch": "bf build --watch",
    "test": "bun test"
  },
  "dependencies": {
    "@barefootjs/client": "0.3.0",
    "@barefootjs/form": "0.3.0",
    "@barefootjs/hono": "0.3.0",
    "@barefootjs/jsx": "0.3.0",
    "@barefootjs/shared": "0.3.0",
    "@hono/zod-validator": "^0.8.0",
    "hono": "^4.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@barefootjs/cli": "0.3.0",
    "@barefootjs/test": "0.3.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/bun": "^1.1.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.6.0"
  }
}
